---
import PageLayout from "@/layouts/Base.astro";
import "@/styles/blocks/search.css";

const enabled = import.meta.env.PROD;
const bundlePath = `${import.meta.env.BASE_URL}pagefind/`;
---

<PageLayout meta={{ title: "Search", description: "Search public notes and writing." }}>
	<div class="search-shell" data-pagefind-ignore>
		<header class="page-header">
			<p class="eyebrow"><span>/</span> search</p>
			<h1 class="page-title">Search</h1>
			<p class="page-intro">Find a subject, command, mechanism, or article.</p>
		</header>
		<div data-bundle-path={bundlePath} data-enabled={String(enabled)} id="pagefind-search">
			{
				!enabled && (
					<div class="empty-state">
						<p>
							The search index is generated by a production build. Run <code>pnpm build</code> and
							preview the result to test search locally.
						</p>
					</div>
				)
			}
		</div>
	</div>
</PageLayout>

<script>
	import { PagefindUI } from "@pagefind/default-ui";

	const element = document.querySelector<HTMLElement>("#pagefind-search");
	if (element?.dataset.enabled === "true") {
		new PagefindUI({
			baseUrl: import.meta.env.BASE_URL,
			bundlePath: element.dataset.bundlePath,
			element: "#pagefind-search",
			showImages: false,
			showSubResults: true,
		});
	}
</script>
