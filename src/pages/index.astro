---
import NoteListItem from "@/components/NoteListItem.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SocialList from "@/components/SocialList.astro";
import WritingListItem from "@/components/WritingListItem.astro";
import { getAllNotes, getAllWriting } from "@/data/content";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";

const [allNotes, allWriting] = await Promise.all([getAllNotes(), getAllWriting()]);
const latestNotes = allNotes.slice(0, 5);
const selectedWriting = [...allWriting]
	.sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
	.slice(0, 3);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="hero">
		<p class="terminal-line"><span>hans@machine</span>:~$ whoami</p>
		<h1>GPU systems, from the kernel up.</h1>
		<p class="hero-lede">Field notes on drivers, firmware, memory, and Linux.</p>
		<p class="hero-copy">
			I'm Hans. I work on GPU systems at a fabless semiconductor company. This is where I
			trace the boundaries between hardware, firmware, the kernel, and the runtime.
		</p>
		<SocialList />
	</section>

	<section aria-labelledby="focus-heading" class="focus-block">
		<h2 id="focus-heading">Current focus</h2>
		<ul class="focus-list">
			{siteConfig.currentFocus.map((focus) => <li>{focus}</li>)}
		</ul>
	</section>

	{
		latestNotes.length > 0 && (
			<section class="home-section">
				<SectionHeading href="/notes/" label="Latest notes" />
				<ul class="entry-list">
					{latestNotes.map((note) => (
						<li><NoteListItem as="h3" note={note} /></li>
					))}
				</ul>
			</section>
		)
	}
	{
		selectedWriting.length > 0 && (
			<section class="home-section">
				<SectionHeading href="/writing/" label="Selected writing" />
				<ul class="entry-list">
					{selectedWriting.map((entry) => (
						<li><WritingListItem as="h3" entry={entry} /></li>
					))}
				</ul>
			</section>
		)
	}
</PageLayout>
