---
import NoteListItem from "@/components/NoteListItem.astro";
import ProjectListItem from "@/components/ProjectListItem.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import SocialList from "@/components/SocialList.astro";
import WritingListItem from "@/components/WritingListItem.astro";
import { getAllNotes, getAllProjects, getAllWriting } from "@/data/content";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";

const [allNotes, allWriting, allProjects] = await Promise.all([
	getAllNotes(),
	getAllWriting(),
	getAllProjects(),
]);
const latestNotes = allNotes.slice(0, 5);
const selectedWriting = [...allWriting]
	.sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
	.slice(0, 3);
const selectedProjects = [...allProjects]
	.sort((a, b) => Number(b.data.featured) - Number(a.data.featured))
	.slice(0, 3);
---

<PageLayout meta={{ title: "Home" }}>
	<section class="hero">
		<p class="terminal-line"><span>hans@machine</span>:~$ whoami</p>
		<h1>Systems field notes.</h1>
		<p class="hero-lede">Learning the layers where software meets the machine.</p>
		<p class="hero-copy">
			I'm Hans. This is a working notebook for short observations, deeper explanations, and
			selected experiments in systems and hardware.
		</p>
		<SocialList />
	</section>

	<section aria-labelledby="focus-heading" class="focus-block">
		<h2 id="focus-heading">Currently exploring</h2>
		<ul class="focus-list">
			{siteConfig.currentFocus.map((focus) => <li>{focus}</li>)}
		</ul>
	</section>

	{
		latestNotes.length > 0 && (
			<section class="home-section">
				<SectionHeading href="/notes/" label="Latest notes" />
				<ul class="entry-list">
					{latestNotes.map((note) => (
						<li><NoteListItem as="h3" note={note} /></li>
					))}
				</ul>
			</section>
		)
	}
	{
		selectedWriting.length > 0 && (
			<section class="home-section">
				<SectionHeading href="/writing/" label="Selected writing" />
				<ul class="entry-list">
					{selectedWriting.map((entry) => (
						<li><WritingListItem as="h3" entry={entry} /></li>
					))}
				</ul>
			</section>
		)
	}
	{
		selectedProjects.length > 0 && (
			<section class="home-section">
				<SectionHeading href="/projects/" label="Projects" />
				<ul class="project-list">
					{selectedProjects.map((project) => (
						<li><ProjectListItem as="h3" project={project} /></li>
					))}
				</ul>
			</section>
		)
	}
</PageLayout>
