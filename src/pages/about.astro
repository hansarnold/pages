---
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site.config";

const meta = {
	description: "About Hans and his interests in systems, hardware, and open-source software.",
	title: "About",
};

const personData = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Hans",
	url: `${siteConfig.url}${siteConfig.base}/about/`,
	sameAs: [siteConfig.github],
	knowsAbout: ["GPU programming", "AI systems", "computer hardware", "Rust", "Linux"],
};
---

<PageLayout meta={meta}>
	<header class="page-header">
		<p class="eyebrow"><span>01</span> / about</p>
		<h1 class="page-title">About</h1>
		<p class="page-intro">A short introduction to the person behind these notes.</p>
	</header>
	<div class="prose prose-sm article-shell" data-pagefind-body>
		<p>
			I'm Hans. I work on GPU systems at a fabless semiconductor company. I'm currently learning
			about systems and hardware, especially the layers where software meets the machine. I enjoy
			tinkering with software that lives in the terminal.
		</p>

		<h2>Currently exploring</h2>
		<ul>
			<li><strong>GPU and AI systems:</strong> GPU programming, CUDA, and efficient compute</li>
			<li><strong>Hardware:</strong> computer architecture, accelerators, and performance</li>
			<li><strong>Systems programming:</strong> Rust, low-level software, drivers, and tooling</li>
			<li><strong>Open systems:</strong> Linux, free software, and open-source tooling</li>
		</ul>

		<h2>About this site</h2>
		<p>
			This site is a public field notebook: short notes for discoveries worth remembering, longer
			explanations when a subject needs room, and a curated record of useful experiments. It is
			intentionally static, lightweight, and kept close to the source files.
		</p>

		<h2>Elsewhere</h2>
		<p>
			Find my public code and repositories on <a
				href={siteConfig.github}
				rel="me noreferrer"
				target="_blank">GitHub</a
			>.
		</p>
	</div>
	<script is:inline type="application/ld+json" set:html={JSON.stringify(personData)} />
</PageLayout>
