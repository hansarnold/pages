---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
	project: CollectionEntry<"project">;
};

const { as: Heading = "h2" } = Astro.props;
const project = Astro.props.project as CollectionEntry<"project">;
const relationshipLabels: Record<
	"built" | "maintained" | "experiment" | "studied" | "forked" | "configured",
	string
> = {
	built: "Built",
	maintained: "Maintained",
	experiment: "Experiment",
	studied: "Studied",
	forked: "Fork",
	configured: "Configured",
};
---

<article class="project-row">
	<div class="project-heading">
		<Heading>{project.data.name}</Heading>
		<div class="project-labels">
			<span>{relationshipLabels[project.data.relationship]}</span>
			<span class={`status status-${project.data.status}`}>{project.data.status}</span>
		</div>
	</div>
	<p>{project.data.description}</p>
	<div class="project-footer">
		<ul aria-label="Project topics" class="project-topics">
			{project.data.topics.map((topic: string) => <li>{topic}</li>)}
		</ul>
		<div class="project-links">
			<a href={project.data.repository} rel="noreferrer" target="_blank">Source <span aria-hidden="true">↗</span></a>
			{project.data.homepage && <a href={project.data.homepage} rel="noreferrer" target="_blank">Visit <span aria-hidden="true">↗</span></a>}
		</div>
	</div>
</article>
